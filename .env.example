# Jetson-specific knobs live at the bottom.

# Required for NVCF cloud services and local NIM containers
NVIDIA_API_KEY=nvapi-...

# Prompt key from prompt.yaml
PROMPT_SELECTOR=flowershop

# Optional host port override for the selector app
# PIPELINE_APP_PORT=7860

# Strip markdown/special chars before TTS synthesis
ENABLE_TTS_TEXT_FILTER=true

# Optional word-to-IPA pronunciation dictionary for NvidiaTTSService.
# JSON or YAML file mapping graphemes to IPA phonemes, e.g. {"NVIDIA": "ɛn.vɪ.diː.ʌ"}.
# Relative paths resolve from the repo root.
# TTS_IPA_FILE_PATH=config/ipa.json

# Required for dgxspark/jetson (vLLM pulls the model from HF)
# HF_TOKEN=hf_...

# Local ASR NIM image override
# ASR_DOCKER_IMAGE=nvcr.io/nim/nvidia/nemotron-asr-streaming:1.0.0
# ASR_DOCKER_IMAGE=nvcr.io/nim/nvidia/parakeet-1-1b-ctc-en-us:1.5.0
# ASR_DOCKER_IMAGE=nvcr.io/nim/nvidia/parakeet-1-1b-rnnt-multilingual:1.5.0
# ASR_NIM_TAGS=mode=str,vad=silero  # Use with Parakeet CTC/RNNT ASR images.

# Local TTS NIM image override
# TTS_DOCKER_IMAGE=nvcr.io/nvstaging/nim/magpie-tts-multilingual:1.8.0-47994010

# Chat history management (initial prompt messages always preserved)
# Summarizes everything older than the latest N user turns.
# CHAT_HISTORY_RECENT_TURNS=10

# Audio output buffering (WebRTC: 5, WebSocket: 10)
# AUDIO_OUT_10MS_CHUNKS=10

# Audio debugging
# ENABLE_ASR_AUDIO_DUMP=false
# ENABLE_TTS_AUDIO_DUMP=false
# AUDIO_DUMP_PATH=audio_dumps/cascaded

# OpenTelemetry tracing — see docs/how-to/enable-opentelemetry-tracing.md
# ENABLE_TRACING=false
# OTEL_CONSOLE_EXPORT=false
# OTEL_EXPORTER_OTLP_ENDPOINT=phoenix:4317

# --- Optional TURN server (remote WebRTC NAT/firewall traversal) -----------
# Enable by launching with the 'turn' profile, for example:
#   docker compose --profile generic --profile turn up -d
#   docker compose --profile generic-workstation --profile turn up -d
# Host firewall must allow UDP 3478 and UDP 49160-49200 from clients.
# Defaults to admin:admin if unset. Override in production.
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=admin
# TURN_PASSWORD=admin


# --- Jetson profile ----------------------------------------------------------
# Tunables specific to Thor. Defaults below are what we run in production.

# CUDA MPS SM-share caps (no-op unless scripts/start-mps.sh is running)
# VLLM_MPS_THREAD_PCT=50
# RIVA_MPS_THREAD_PCT=50

# CPU pinning on Thor's 14 cores (disjoint sets). Pipecat pinned via `taskset`.
# VLLM_CPUSET=0-3
# RIVA_CPUSET=4-7
# PIPECAT_CPUSET=8-11

# Path to Riva model repo built by `bash riva_init.sh` (mounted as /data)
# RIVA_MODEL_LOC=../riva_quickstart_arm64_v2.24.0/model_repository
