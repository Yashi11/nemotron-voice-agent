# [REQUIRED] Your NVIDIA API key from build.nvidia.com
NVIDIA_API_KEY=

# Enable speculative speech for lower latency responses
ENABLE_SPECULATIVE_SPEECH=true

# Path to custom prompt catalog file
PROMPT_FILE_PATH=./prompt.yaml

# [OPTIONAL] Limit chat history context (number of messages)
CHAT_HISTORY_LIMIT=

# System prompt selector (path in prompt.yaml: model/persona)
# For multilingual mode, use: llama-3_3-nemotron-super-49b-v1_5/multilingual_voice_assistant
SYSTEM_PROMPT_SELECTOR=llama-3.1-8b-instruct/flowershop

# LLM endpoint URL (cloud API or local NIM e.g. http://localhost:18000/v1)
NVIDIA_LLM_URL=
NVIDIA_LLM_MODEL=meta/llama-3.1-8b-instruct

# Enable multilingual mode (requires multilingual ASR model)
ENABLE_MULTILINGUAL=false

# ASR container image
RIVA_ASR_IMAGE=nvcr.io/nim/nvidia/parakeet-1-1b-ctc-en-us:1.3.0

# ASR model tags
RIVA_ASR_TAGS=mode=str,vad=silero

# LLM container image
NVIDIA_LLM_IMAGE=nvcr.io/nim/meta/llama-3.1-8b-instruct:1.8.6

# ASR endpoint URL (cloud API or local NIM e.g. localhost:50152)
RIVA_ASR_URL=
RIVA_ASR_LANGUAGE=en-US
RIVA_ASR_MODEL=parakeet-1.1b-en-US-asr-streaming-silero-vad-sortformer

# TTS endpoint URL (cloud API or local NIM e.g. localhost:50151)
RIVA_TTS_URL=
RIVA_TTS_VOICE_ID=Magpie-Multilingual.EN-US.Aria
RIVA_TTS_MODEL=magpie_tts_ensemble-Magpie-Multilingual
RIVA_TTS_LANGUAGE=en-US
